# ============================================
# RetailVision AI - Environment Configuration
# ============================================
# Copy this file to .env and update values

# SERVICE CONFIGURATION
SERVICE_NAME=RetailVision AI
SERVICE_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True

# BACKEND API
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=4
API_TITLE=RetailVision AI API
API_VERSION=1.0.0

# DATABASE
DATABASE_URL=postgresql://retailvision:retailvision@postgres:5432/retailvision_db
SQLALCHEMY_ECHO=False

# REDIS
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# VIDEO INGESTION
VIDEO_SOURCE_TYPE=rtsp  # rtsp, webcam, file
VIDEO_RTSP_URL=rtsp://your-camera-ip:554/stream
VIDEO_WEBCAM_ID=0
VIDEO_FILE_PATH=/data/video.mp4
VIDEO_FPS_LIMIT=15
FRAME_BUFFER_SIZE=30

# MODEL INFERENCE
USE_GPU=True
GPU_DEVICE_ID=0
YOLO_CONFIDENCE_THRESHOLD=0.5
YOLO_IOU_THRESHOLD=0.45
TRACKING_CONFIDENCE_THRESHOLD=0.3

# SHELF ZONES (JSON format)
SHELF_ZONES=[{"id":"shelf_1","x":100,"y":100,"width":300,"height":200},{"id":"shelf_2","x":400,"y":100,"width":300,"height":200}]

# REDIS STREAMS
EVENTS_STREAM_KEY=retailvision:events
EVENTS_CONSUMER_GROUP=analytics-workers
EVENT_BATCH_SIZE=100

# LOGGING
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/logs/backend.log

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# JWT (if auth enabled)
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# FRONTEND
FRONTEND_URL=http://localhost:3000
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3000

# NEXT.JS
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# MONITORING
SENTRY_DSN=
PROMETHEUS_METRICS_ENABLED=True

# STORAGE
DATA_DIR=/data
MODELS_DIR=/models
LOGS_DIR=/logs

# TIMEOUTS (seconds)
VIDEO_READ_TIMEOUT=30
INFERENCE_TIMEOUT=10
DB_QUERY_TIMEOUT=30
