# RetailVision AI - Frontend Environment Configuration
# Copy this to .env.local and update values for your environment

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_API_KEY=demo-key-12345

# Feature Flags
NEXT_PUBLIC_ENABLE_HEATMAP=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_ALERTS=true
NEXT_PUBLIC_ENABLE_CUSTOMERS=true

# UI Configuration
NEXT_PUBLIC_DARK_MODE_DEFAULT=false
NEXT_PUBLIC_REFRESH_INTERVAL=30000
NEXT_PUBLIC_REALTIME_ENABLED=true

# Analytics Configuration
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_ANALYTICS_ID=

# Other
NODE_ENV=development
