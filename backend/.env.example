# RetailVision AI - Backend Environment Configuration
# For local development with localhost testing
# Copy this to .env and adjust values as needed

# ==========================================
# Service Configuration
# ==========================================
SERVICE_NAME=RetailVision AI
SERVICE_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# ==========================================
# API Configuration
# ==========================================
API_TITLE=RetailVision AI API
API_VERSION=1.0.0
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=4

# ==========================================
# Database Configuration
# ==========================================
# For local development: PostgreSQL on Docker
DATABASE_URL=postgresql://retailvision:retailvision_dev@localhost:5432/retailvision_db
SQLALCHEMY_ECHO=false

# ==========================================
# Redis Configuration
# ==========================================
# For local development: Redis on Docker
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ==========================================
# Video Ingestion Configuration
# ==========================================
# Options: rtsp, webcam, file
VIDEO_SOURCE_TYPE=file

# RTSP stream URL (if VIDEO_SOURCE_TYPE=rtsp)
VIDEO_RTSP_URL=rtsp://localhost:554/stream

# Webcam device ID (if VIDEO_SOURCE_TYPE=webcam)
VIDEO_WEBCAM_ID=0

# Local MP4 file path (if VIDEO_SOURCE_TYPE=file)
VIDEO_FILE_PATH=/tmp/retailvision/data/sample.mp4

# Video processing settings
VIDEO_FPS_LIMIT=15
FRAME_BUFFER_SIZE=30

# ==========================================
# Model Inference Configuration
# ==========================================
USE_GPU=false
GPU_DEVICE_ID=0
YOLO_CONFIDENCE_THRESHOLD=0.5
YOLO_IOU_THRESHOLD=0.45
TRACKING_CONFIDENCE_THRESHOLD=0.3

# ==========================================
# Shelf Zones Configuration
# ==========================================
# JSON array of zone definitions
SHELF_ZONES=[
  {"zone_id": 1, "name": "Electronics", "type": "high_value", "coordinates": [0, 0, 640, 360]},
  {"zone_id": 2, "name": "Produce", "type": "general", "coordinates": [640, 0, 1280, 360]},
  {"zone_id": 3, "name": "Dairy", "type": "general", "coordinates": [0, 360, 640, 720]}
]

# ==========================================
# Redis Streams Configuration
# ==========================================
EVENTS_STREAM_KEY=retailvision:events
EVENTS_CONSUMER_GROUP=analytics-workers
EVENT_BATCH_SIZE=100

# ==========================================
# Logging Configuration
# ==========================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/tmp/retailvision/logs/backend.log

# ==========================================
# CORS Configuration
# ==========================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://127.0.0.1:3000","http://127.0.0.1:8000"]

# ==========================================
# JWT Configuration (for authentication)
# ==========================================
JWT_SECRET_KEY=change-me-in-production-with-strong-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ==========================================
# Frontend URLs
# ==========================================
FRONTEND_URL=http://localhost:3000
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3000

# ==========================================
# Next.js Configuration
# ==========================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ==========================================
# Storage Paths
# ==========================================
DATA_DIR=/tmp/retailvision/data
MODELS_DIR=/tmp/retailvision/models
LOGS_DIR=/tmp/retailvision/logs

# ==========================================
# Timeouts (seconds)
# ==========================================
VIDEO_READ_TIMEOUT=30
INFERENCE_TIMEOUT=10
DB_QUERY_TIMEOUT=30

# ==========================================
# Optional: Monitoring & Observability
# ==========================================
SENTRY_DSN=
PROMETHEUS_METRICS_ENABLED=true
